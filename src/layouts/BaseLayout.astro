---
//src/layoutasts/BaseLayout.astro
interface Props {
    title: string;
}

const {title} = Astro.props;

---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <style is:global>
      /* Al poner 'is:global', estos estilos afectarán a TODA la web */
      body {
        font-family: system-ui, -apple-system, sans-serif;
        background-color: #0f172a;
        color: #f8fafc;
        max-width: 800px;
        margin: 60px auto;
        padding: 0 20px;
      }
      header { border-bottom: 1px solid #334155; padding-bottom: 2rem; margin-bottom: 2rem; }
      h1 { color: #38bdf8; font-size: 2.5rem; margin-bottom: 0.5rem; }
      h2 { color: #94a3b8; font-size: 1.5rem; font-weight: 400; margin-top: 0; }
    </style>
  </head>
  <body>
    <!-- Reservado para el contenido principal -->
    <slot />

  </body>
---
// 1. ESPACIO DE INGENIERÍA (Backend de Astro) Solo se ejecuta en el servidor.
// Importamos nuestro JSON directamente.  
// lo convierte automáticamente en un array de objetos TypeScript.
import projectsData from '../data/projects.json';

const name = "Germán";
const role = "Software Engineer Student & Backend Developer";
const sub = "Técnico Superior en DAM y estudiante de Ingeniería Informática. Especializado en el ecosistema Java / Spring Boot. Sigo una arquitectura limpia y me gusta automatizar cosas.";
---

<!-- 2. ESPACIO DE VISTA (HTML + CSS) -->
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Portfolio - {name}</title>
    <style>
      body {
        font-family: system-ui, -apple-system, sans-serif;
        background-color: #0f172a;
        color: #f8fafc;
        max-width: 800px;
        margin: 60px auto;
        padding: 0 20px;
      }
      header { border-bottom: 1px solid #334155; padding-bottom: 2rem; margin-bottom: 2rem; }
      h1 { color: #38bdf8; font-size: 2.5rem; margin-bottom: 0.5rem; }
      h2 { color: #94a3b8; font-size: 1.5rem; font-weight: 400; margin-top: 0; }
      
      /* Estilos para nuestras tarjetas de proyectos */
      .project-card {
        background-color: #1e293b;
        border: 1px solid #334155;
        border-radius: 8px;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
      }
      .project-title { color: #f8fafc; margin: 0 0 0.5rem 0; font-size: 1.25rem; }
      .project-type { color: #38bdf8; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.05em; font-weight: bold; }
      .tag-container { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 1rem; }
      .tag { background-color: #334155; color: #cbd5e1; padding: 0.2rem 0.6rem; border-radius: 4px; font-size: 0.85rem; }
    </style>
  </head>
  <body>
    
    <header>
      <h1>Hola, soy {name} 👋</h1>
      <h2>{role}</h2>
      <p>{sub}</p>
    </header>

    <main>
      <h3>Proyectos Destacados</h3>
      
      <!-- LA MAGIA DE LA ITERACIÓN: 
           Recorremos el array 'projectsData'. Por cada 'project', 
           Astro renderizará este bloque HTML automáticamente. -->
      {projectsData.map((project) => (
        <article class="project-card">
          <span class="project-type">{project.type}</span>
          <h4 class="project-title">{project.title} ({project.year})</h4>
          <p>{project.description}</p>
          
          <div class="tag-container">
            <!-- Hacemos un sub-bucle para pintar las tecnologías (stack) -->
            {project.stack.map((tech) => (
              <span class="tag">{tech}</span>
            ))}
          </div>
        </article>
      ))}

    </main>

  </body>
</html>